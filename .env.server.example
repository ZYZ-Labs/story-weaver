BACKEND_IMAGE=crpi-2iicgf8z27uyvaq1.cn-hangzhou.personal.cr.aliyuncs.com/silvericekey/story-weaver-backend:1.0.0
FRONTEND_IMAGE=crpi-2iicgf8z27uyvaq1.cn-hangzhou.personal.cr.aliyuncs.com/silvericekey/story-weaver-front:1.0.0

BACKEND_PORT=8080
HTTP_PORT=80
HTTPS_PORT=443
TZ=Asia/Shanghai

SERVER_NAME=home.silvericekey.fun
SSL_CERT_DIR=/usr/local/project/cer
SSL_CERT_FILE=/etc/nginx/ssl/fullchain.pem
SSL_CERT_KEY_FILE=/etc/nginx/ssl/privkey.pem

BACKEND_LOG_DIR=./volumes/backend/logs
FRONTEND_LOG_DIR=./volumes/front/nginx-logs
GATEWAY_LOG_DIR=./volumes/gateway/nginx-logs

SPRING_DATASOURCE_URL=jdbc:mysql://192.168.5.249:3306/story_weaver?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=your_mysql_username
SPRING_DATASOURCE_PASSWORD=your_mysql_password

SPRING_DATA_REDIS_HOST=192.168.5.249
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=your_redis_password

JWT_SECRET=change-this-to-a-long-random-jwt-secret-at-least-32-characters
APP_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*,http://192.168.*:*,http://10.*:*,https://home.silvericekey.fun,https://home.silvericekey.fun:*
